section .data
intro_msg db 'Welcome to Student Grade System',0xA,0
intro_len equ $ - intro_msg

ask_student_name db 'Please Enter the Student Name: ',0
ask_student_name_len equ $ - ask_student_name

ask_num_of_subject db 'How Many Subjects do you want to calculate?'
ask_num_of_subject_len eqy $ - ask_num_of_subject

ask_score db 'Please enter the score: ',0
ask_score_len equ $ -ask_score

error_msg db 'Invalid input! Please Enter again.',0xA,0
error_msg_len equ $ - error_msg

result_msg db 'Total Score: ',0
result_msg_len equ $ - result_msg

newline db 0xA

section .bss
StudentName resb 20
NumberOfSubject resb 2
Score resb 4
TotalScore resb 4


section .text
    global _start

_start:
    mov eax,4
    mov ebx,1
    mov ecx,intro_msg
    mov edx,intro_len
    int 0x80
    
    ;ask/read name and num of subject
    mov eax,4
    mov ebx,1
    mov ecx,ask_student_name
    mov edx,ask_student_name_len
    int 0x80
    
    mov eax,3
    mov ebx,0
    mov ecx,StudentName
    mov edx,20
    int 0x80
    
    mov eax,4
    mov ebx,1
    mov ecx,ask_num_of_subject
    mov edx,ask_num_of_subject_len
    int 0x80
    
    mov eax,3
    mov ebx,0
    mov ecx,NumberOfSubject
    mov edx,2
    int 0x80
    
    
    ;convert ascii to number
    mov al,[NumberOfSubject]
    sub al,'0'
    mov [NumberOfSubject],al
    
    ;initialize total score
    mov byte[TotalScore],0
    
    ;ask score
loop_start:
cmp byte[NumberOfSubject],0
je display_score

mov eax,4
mov ebx,1
mov ecx,ask_score
mov edx,ask_score_len
int 0x80

mov eax,3
mov ebx,0
mov ecx,Score
mov edx,4
int 0x80

;convert ascii to number
mov al,[Score]
sub al,'0'

add [TotalScore],al

;decrease sbject count
sub byte [NumberOfSubject],1

jmp loop_start


;display score
display_score:

mov eax,4
mov ebx,1
mov ecx,result_msg
mov edx,result_msg_len
int 0x80

;convert number (total score) to ascii
mov al,[TotalScore]
add al,'0'
mov [TotalScore],al

mov eax,4
mov ebx,1
mov ecx,TotalScore
mov edx,1
int 0x80
    
    ;exit
    mov eax,1
    mov ebx,0
    int 0x80
